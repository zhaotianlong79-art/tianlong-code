# Copy this file to .env and fill in your values.
#   cp .env.example .env
# .env is gitignored — never commit real keys.

# Choose ONE protocol by setting its base URL (comment out the other).
# Anthropic-compatible: requests {BASE}/v1/messages, auth via x-api-key.
Anthropic_BASE_URL=https://your-endpoint.example.com/anthropic
# OpenAI-compatible: requests {BASE}/chat/completions, auth via Authorization: Bearer.
# OPENAI_BASE_URL=https://your-endpoint.example.com/v2

# API key (sent as x-api-key for Anthropic, Bearer token for OpenAI).
API_KEY=your-api-key-here

# Model id to use.
MODEL_ID=your-model-id

# Optional: model context window in tokens (history is trimmed to fit).
# TIANLONG_CONTEXT_WINDOW=32768
